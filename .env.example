# ─── REPOLORE BACKEND ENV ───────────────────────────────────
# Copy this to .env and fill in your values

PORT=4000
NODE_ENV=development

# URL of your React frontend (for CORS)
CLIENT_URL=http://localhost:5173

# Optional: GitHub Personal Access Token (increases rate limits 60→5000 req/hr)
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here

# Admin key for /api/messages endpoint
ADMIN_KEY=change_this_to_a_strong_secret

# Optional: Email via Nodemailer (for contact form notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=Techmunda21@gmail.com
# SMTP_PASS=your_app_password
